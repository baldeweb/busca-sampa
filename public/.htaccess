# SPA routing fallback (Hostinger Apache/LiteSpeed)
# - Prevents refresh/pull-to-refresh on /search, /bairro/... etc from hitting server 404
# - Keeps existing files and folders working

<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If the requested path is an existing file or directory, serve it as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, route everything to the SPA entry
  RewriteRule ^ index.html [L]
</IfModule>
